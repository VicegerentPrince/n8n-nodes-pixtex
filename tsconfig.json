{
  "compilerOptions": {
    "strict": true,
    "module": "commonjs",
    "moduleResolution": "node",
    "target": "es2021",
    "lib": ["es2021"],
    "esModuleInterop": true,
    "skipLibCheck": true,
    "outDir": "dist",
    "forceConsistentCasingInFileNames": true,
    "noUnusedLocals": true,
    "useUnknownInCatchVariables": true
  },
  "include": ["credentials/**/*.ts", "nodes/**/*.ts"]
}
