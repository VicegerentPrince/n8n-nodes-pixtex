{
  "name": "n8n-nodes-pixtex",
  "version": "0.1.9",
  "description": "Render n8n workflows into share-ready diagrams from inside n8n — one-off images or permanent hosted URLs, powered by the Pixtex render API.",
  "keywords": [
    "n8n-community-node-package",
    "n8n",
    "workflow",
    "diagram",
    "export",
    "screenshot",
    "image",
    "pixtex"
  ],
  "homepage": "https://pixtex.dev/developers",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/VicegerentPrince/n8n-nodes-pixtex.git"
  },
  "bugs": "https://github.com/VicegerentPrince/n8n-nodes-pixtex/issues",
  "license": "MIT",
  "author": {
    "name": "Muhammad Muneeb",
    "email": "muneebshahzad7128@gmail.com",
    "url": "https://github.com/VicegerentPrince"
  },
  "engines": {
    "node": ">=20"
  },
  "files": [
    "dist",
    "!dist/**/*.d.ts",
    "!dist/**/*.map",
    "!dist/package.json",
    "!dist/*.tsbuildinfo"
  ],
  "scripts": {
    "build": "n8n-node build && node scripts/copy-assets.mjs",
    "dev": "n8n-node dev",
    "typecheck": "tsc -p tsconfig.test.json",
    "lint": "n8n-node lint",
    "lint:fix": "n8n-node lint --fix",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "npm run build"
  },
  "n8n": {
    "n8nNodesApiVersion": 1,
    "strict": true,
    "credentials": [
      "dist/credentials/PixtexApi.credentials.js"
    ],
    "nodes": [
      "dist/nodes/Pixtex/Pixtex.node.js"
    ]
  },
  "devDependencies": {
    "@n8n/node-cli": "^0.39.3",
    "@types/node": "^24.0.0",
    "eslint": "9.29.0",
    "n8n-workflow": "^2.16.0",
    "typescript": "^5.8.3",
    "vitest": "^4.1.10"
  },
  "peerDependencies": {
    "n8n-workflow": "*"
  }
}
