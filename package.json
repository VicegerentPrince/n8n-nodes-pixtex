{
  "name": "n8n-nodes-pixtex",
  "version": "0.1.3",
  "description": "Render n8n workflows into share-ready diagrams from inside n8n — one-off images or permanent hosted URLs, powered by the Pixtex render API.",
  "keywords": [
    "n8n-community-node-package",
    "n8n",
    "workflow",
    "diagram",
    "export",
    "screenshot",
    "image",
    "pixtex"
  ],
  "homepage": "https://pixtex.dev/developers",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/VicegerentPrince/n8n-nodes-pixtex.git"
  },
  "bugs": "https://github.com/VicegerentPrince/n8n-nodes-pixtex/issues",
  "license": "MIT",
  "author": {
    "name": "Muhammad Muneeb",
    "email": "muneebshahzad7128@gmail.com",
    "url": "https://github.com/VicegerentPrince"
  },
  "engines": {
    "node": ">=20"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json && node scripts/copy-assets.mjs",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "npm run build"
  },
  "n8n": {
    "n8nNodesApiVersion": 1,
    "credentials": [
      "dist/credentials/PixtexApi.credentials.js"
    ],
    "nodes": [
      "dist/nodes/Pixtex/Pixtex.node.js"
    ]
  },
  "devDependencies": {
    "@n8n/eslint-plugin-community-nodes": "^0.24.0",
    "@types/node": "^24.0.0",
    "eslint": "^9.29.0",
    "eslint-plugin-n8n-nodes-base": "^1.16.7",
    "n8n-workflow": "^2.16.0",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.64.0",
    "vitest": "^4.1.10"
  },
  "peerDependencies": {
    "n8n-workflow": "*"
  }
}
